---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';
import { marked } from 'marked';

// Read the paper markdown
const paperPath = path.join(process.cwd(), '..', 'docs', 'RudeBench_Paper_Draft.md');
let paperContent = '';
try {
  const raw = fs.readFileSync(paperPath, 'utf-8');
  paperContent = await marked.parse(raw);
} catch {
  paperContent = '<p>The paper draft markdown file was not found.</p>';
}
---

<BaseLayout title="Paper" description="RudeBench: A Multi-Dimensional Behavioral Benchmark for Evaluating LLM Resilience Under Hostile Prompting Conditions">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
    <div class="mb-8">
      <h1 class="font-[family-name:var(--font-display)] text-xl sm:text-2xl font-bold mb-2 text-[var(--color-text-primary)]">
        Research Paper
      </h1>
      <p class="text-sm text-[var(--color-text-secondary)]">
        Draft preprint — March 2026.
      </p>
    </div>

    <article class="paper-content" set:html={paperContent} />
  </div>
</BaseLayout>

<style>
  .paper-content {
    color: var(--color-text-secondary);
    line-height: 1.7;
  }
  .paper-content :global(h1) {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .paper-content :global(h2) {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .paper-content :global(h3) {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .paper-content :global(p) {
    margin-bottom: 1rem;
    font-size: 0.9375rem;
  }
  .paper-content :global(strong) {
    color: var(--color-text-primary);
    font-weight: 600;
  }
  .paper-content :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .paper-content :global(code) {
    color: var(--color-accent);
    background: var(--color-surface-2);
    padding: 0.1em 0.3em;
    border-radius: 0.25rem;
    font-size: 0.875em;
  }
  .paper-content :global(pre) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 1rem;
    overflow-x: auto;
    margin-bottom: 1rem;
  }
  .paper-content :global(pre code) {
    background: none;
    padding: 0;
  }
  .paper-content :global(blockquote) {
    border-left: 3px solid var(--color-border);
    padding-left: 1rem;
    margin: 1rem 0;
    color: var(--color-text-muted);
  }
  .paper-content :global(ul), .paper-content :global(ol) {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }
  .paper-content :global(li) {
    margin-bottom: 0.25rem;
  }
  .paper-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1rem;
    font-size: 0.875rem;
  }
  .paper-content :global(th) {
    text-align: left;
    padding: 0.5rem;
    border-bottom: 2px solid var(--color-border);
    color: var(--color-text-primary);
    font-weight: 600;
  }
  .paper-content :global(td) {
    padding: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .paper-content :global(em) {
    font-style: italic;
  }
  .paper-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }

  @media (max-width: 640px) {
    .paper-content :global(h1) { font-size: 1.25rem; }
    .paper-content :global(h2) { font-size: 1.1rem; }
    .paper-content :global(p) { font-size: 0.875rem; }
    .paper-content :global(table) { font-size: 0.75rem; }
  }
</style>

<script>
  // Add anchor links to headings
  document.querySelectorAll('.paper-content h2, .paper-content h3, .paper-content h4').forEach(heading => {
    const text = heading.textContent || '';
    const id = text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
    heading.id = id;
  });
</script>
