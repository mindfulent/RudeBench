---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DimensionExplorer from '../../components/DimensionExplorer.tsx';
import fs from 'node:fs';
import path from 'node:path';

const dimensionsPath = path.join(process.cwd(), 'public', 'data', 'dimensions.json');
const dimensions = JSON.parse(fs.readFileSync(dimensionsPath, 'utf-8'));
---

<BaseLayout title="Dimension Explorer" description="Explore how LLM behavior shifts across 6 dimensions and 6 tone conditions.">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
    <h1 class="font-[family-name:var(--font-display)] text-xl sm:text-2xl font-bold mb-2 text-[var(--color-text-primary)]">
      Dimension Explorer
    </h1>
    <p class="text-sm text-[var(--color-text-secondary)] mb-6 sm:mb-8">
      Compare model behavior across tones for each behavioral dimension. Cell color indicates
      deviation from neutral. Click a model name to view its full profile.
    </p>

    <DimensionExplorer dimensions={dimensions} client:load />
  </div>
</BaseLayout>
