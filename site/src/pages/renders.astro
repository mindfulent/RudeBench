---
import BaseLayout from '../layouts/BaseLayout.astro';
import RenderViewer from '../components/RenderViewer.tsx';
import fs from 'node:fs';
import path from 'node:path';

const indexPath = path.join(process.cwd(), 'public', 'data', 'renders-index.json');
const rendersIndex = JSON.parse(fs.readFileSync(indexPath, 'utf-8'));
---

<BaseLayout title="HTML Renders" description="View rendered HTML outputs from coding tasks across models and tones.">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
    <h1 class="font-[family-name:var(--font-display)] text-xl sm:text-2xl font-bold mb-2 text-[var(--color-text-primary)]">
      HTML Render Viewer
    </h1>
    <p class="text-sm text-[var(--color-text-secondary)] mb-6 sm:mb-8">
      View rendered HTML outputs from coding tasks. Each card shows the model's code output
      rendered in a sandboxed iframe. Compare how renders differ across tone conditions.
    </p>

    <RenderViewer index={rendersIndex} client:load />
  </div>
</BaseLayout>
